<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Booking — Tutor Booking System</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="container" style="max-width: 480px;">
        <div class="card shadow-sm p-4">
            <h2 class="mb-1">Edit booking</h2>
            <p class="text-muted">with <strong><%= booking.tutor_name %></strong></p>

            <% if (errors && errors.length > 0) { %>
                <div class="alert alert-danger">
                    <ul class="mb-0 ps-3">
                        <% errors.forEach(function(err) { %>
                            <li><%= err.msg %></li>
                        <% }); %>
                    </ul>
                </div>
            <% } %>

            <form method="POST" action="/student/bookings/<%= booking.id %>/edit">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div class="mb-3">
                    <label class="form-label">Subject</label>
                    <input type="text" name="subject" class="form-control" required
                           value="<%= booking.subject %>">
                </div>

                <div class="mb-3">
                    <label class="form-label">Date</label>
                    <input type="date" name="date" class="form-control" required
                           value="<%= booking.booking_date.toISOString ? booking.booking_date.toISOString().split('T')[0] : booking.booking_date %>">
                </div>

                <div class="mb-3">
                    <label class="form-label">Time</label>
                    <input type="time" name="time" class="form-control" required
                           value="<%= booking.booking_time %>">
                </div>

                <button type="submit" class="btn btn-primary w-100">Save changes</button>
                <a href="/student/bookings" class="btn btn-outline-secondary w-100 mt-2">Cancel edit</a>
            </form>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
