<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Dashboard — Tutor Booking System</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="container">
        <% if (flashSuccess) { %>
            <div class="alert alert-success"><%= flashSuccess %></div>
        <% } %>

        <div class="card shadow-sm p-4 mb-4">
            <h2>Welcome, <%= user.name %></h2>
            <p class="text-muted mb-0">
                You have <strong><%= totalBookings %></strong> total booking(s) &middot;
                <strong><%= pending.length %></strong> pending
            </p>
            <div class="mt-3">
                <a href="/student/tutors" class="btn btn-primary">Browse tutors</a>
                <a href="/student/bookings" class="btn btn-outline-secondary">View all my bookings</a>
            </div>
        </div>

        <div class="card shadow-sm p-4 mb-4">
            <h4 class="mb-3">Pending requests (<%= pending.length %>)</h4>
            <% if (pending.length === 0) { %>
                <p class="text-muted mb-0">No pending requests.</p>
            <% } else { %>
                <ul class="list-group list-group-flush">
                    <% pending.forEach(function(b) { %>
                        <li class="list-group-item d-flex justify-content-between">
                            <span><%= b.subject %> with <%= b.tutor_name %> —
                                <%= b.booking_date.toISOString ? b.booking_date.toISOString().split('T')[0] : b.booking_date %>
                                at <%= b.booking_time %></span>
                            <span class="badge bg-warning text-dark">pending</span>
                        </li>
                    <% }); %>
                </ul>
            <% } %>
        </div>

        <div class="card shadow-sm p-4">
            <h4 class="mb-3">Upcoming approved sessions</h4>
            <% if (approved.length === 0) { %>
                <p class="text-muted mb-0">No approved sessions yet.</p>
            <% } else { %>
                <ul class="list-group list-group-flush">
                    <% approved.forEach(function(b) { %>
                        <li class="list-group-item d-flex justify-content-between">
                            <span><%= b.subject %> with <%= b.tutor_name %> —
                                <%= b.booking_date.toISOString ? b.booking_date.toISOString().split('T')[0] : b.booking_date %>
                                at <%= b.booking_time %></span>
                            <span class="badge bg-success">approved</span>
                        </li>
                    <% }); %>
                </ul>
            <% } %>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
