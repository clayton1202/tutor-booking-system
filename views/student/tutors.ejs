<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Browse Tutors — Tutor Booking System</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="container">
        <div class="card shadow-sm p-4 mb-4">
            <h2 class="mb-3">Browse tutors</h2>

            <!-- Search/filter form: by subject AND by max hourly rate (2 criteria) -->
            <form method="GET" action="/student/tutors" class="row g-2 mb-0">
                <div class="col-auto">
                    <input type="text" name="subject" class="form-control" placeholder="Subject (e.g. Math)"
                           value="<%= filters.subject %>">
                </div>
                <div class="col-auto">
                    <input type="number" name="maxRate" class="form-control" placeholder="Max rate (RM/hr)"
                           min="0" step="0.01" value="<%= filters.maxRate %>">
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary">Search</button>
                    <a href="/student/tutors" class="btn btn-outline-secondary">Clear</a>
                </div>
            </form>
        </div>

        <% if (tutors.length === 0) { %>
            <div class="card shadow-sm p-4">
                <p class="text-muted mb-0">No tutors match your search.</p>
            </div>
        <% } else { %>
            <div class="row g-3">
                <% tutors.forEach(function(t) { %>
                    <div class="col-md-6">
                        <div class="card shadow-sm p-3 h-100">
                            <h5><%= t.name %></h5>
                            <p class="mb-1"><strong>Subject:</strong> <%= t.subject %></p>
                            <p class="mb-1"><strong>Rate:</strong> RM<%= t.hourly_rate %>/hr</p>
                            <p class="text-muted small flex-grow-1"><%= t.bio || 'No bio provided.' %></p>
                            <a href="/student/book?tutorId=<%= t.user_id %>" class="btn btn-primary mt-2">
                                Book a session
                            </a>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } %>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
