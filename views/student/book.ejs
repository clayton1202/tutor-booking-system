<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book <%= tutor.name %> — Tutor Booking System</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="container" style="max-width: 520px;">
        <div class="card shadow-sm p-4">
            <h2 class="mb-1">Book a session</h2>
            <p class="text-muted">with <strong><%= tutor.name %></strong> (RM<%= tutor.hourly_rate %>/hr)</p>

            <% if (errors && errors.length > 0) { %>
                <div class="alert alert-danger">
                    <ul class="mb-0 ps-3">
                        <% errors.forEach(function(err) { %>
                            <li><%= err.msg %></li>
                        <% }); %>
                    </ul>
                </div>
            <% } %>

            <form method="POST" action="/student/book">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <input type="hidden" name="tutorId" value="<%= tutor.user_id %>">

                <div class="mb-3">
                    <label class="form-label">Subject</label>
                    <input type="text" name="subject" class="form-control" required
                           value="<%= oldInput.subject || tutor.subject %>">
                </div>

                <div class="mb-3">
                    <label class="form-label">Date</label>
                    <input type="date" name="date" class="form-control" required
                           value="<%= oldInput.date || '' %>">
                </div>

                <div class="mb-3">
                    <label class="form-label">Time</label>
                    <input type="time" name="time" class="form-control" required
                           value="<%= oldInput.time || '' %>">
                </div>

                <button type="submit" class="btn btn-primary w-100">Send booking request</button>
            </form>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
