<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Schedule — Tutor Booking System</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="container">
        <div class="card shadow-sm p-4 mb-4">
            <h2 class="mb-3">My schedule</h2>

            <!-- Search/filter form: filters by status AND date (2 criteria) -->
            <form method="GET" action="/tutor/schedule" class="row g-2 mb-0">
                <div class="col-auto">
                    <select name="status" class="form-select">
                        <option value="">All statuses</option>
                        <option value="pending" <% if (filters.status === 'pending') { %>selected<% } %>>Pending</option>
                        <option value="approved" <% if (filters.status === 'approved') { %>selected<% } %>>Approved</option>
                        <option value="rejected" <% if (filters.status === 'rejected') { %>selected<% } %>>Rejected</option>
                        <option value="cancelled" <% if (filters.status === 'cancelled') { %>selected<% } %>>Cancelled</option>
                    </select>
                </div>
                <div class="col-auto">
                    <input type="date" name="date" class="form-control" value="<%= filters.date %>">
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary">Filter</button>
                    <a href="/tutor/schedule" class="btn btn-outline-secondary">Clear</a>
                </div>
            </form>
        </div>

        <div class="card shadow-sm p-4">
            <% if (bookings.length === 0) { %>
                <p class="text-muted mb-0">No bookings match this filter.</p>
            <% } else { %>
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Student</th>
                                <th>Subject</th>
                                <th>Date</th>
                                <th>Time</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% bookings.forEach(function(b) { %>
                                <tr>
                                    <td><%= b.student_name %></td>
                                    <td><%= b.subject %></td>
                                    <td><%= b.booking_date.toISOString ? b.booking_date.toISOString().split('T')[0] : b.booking_date %></td>
                                    <td><%= b.booking_time %></td>
                                    <td>
                                        <% const badgeClass = {
                                            pending: 'bg-warning text-dark',
                                            approved: 'bg-success',
                                            rejected: 'bg-danger',
                                            cancelled: 'bg-secondary'
                                        }[b.status] || 'bg-secondary'; %>
                                        <span class="badge <%= badgeClass %>"><%= b.status %></span>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
